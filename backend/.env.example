# Database
DATABASE_URL="mysql://user:password@localhost:3306/linkhub"

# JWT
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# Server
PORT=58741
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:58742"

# Site Check Service
SITE_CHECK_ENABLED=true
SITE_CHECK_INTERVAL=30
SITE_CHECK_TIMEOUT=10000

# Initial admin password (used by `npm run db:seed`; change after first login)
ADMIN_DEFAULT_PASSWORD=""
